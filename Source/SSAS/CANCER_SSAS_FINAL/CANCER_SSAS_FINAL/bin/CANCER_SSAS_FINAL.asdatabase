      <MdxScripts>
        <MdxScript>
          <ID>MdxScript</ID>
          <Name>MdxScript</Name>
          <CreatedTimestamp>0001-01-01T00:00:00Z</CreatedTimestamp>
          <LastSchemaUpdate>0001-01-01T00:00:00Z</LastSchemaUpdate>
          <Commands>
            <Command>
              <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;          
CREATE MEMBER CURRENTCUBE.[Measures].[Survival Rate]
 AS IIF(
    [Measures].[Patient Count] = 0,
    NULL,
    (
        ( [Measures].[Patient Count], [DIM OUTCOME].[Survival Status].[Alive] ) 
        / 
        [Measures].[Patient Count]
    )
), 
FORMAT_STRING = "#,##0.00%;-#,##0.00%", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'FACT CANCER';         
CREATE DYNAMIC SET CURRENTCUBE.[Cau9]
 AS FILTER(
   [DIM PATIENT].[Age Group].[Age Group].MEMBERS,
   [Measures].[Survival Rate] &gt; 0.50
);  
CREATE DYNAMIC SET CURRENTCUBE.[cau11]
 AS TOPCOUNT([DIM LOCATION].[Province].CHILDREN,10,( [Measures].[Survival Rate]) 
);       
CREATE DYNAMIC SET CURRENTCUBE.[cau10]
 AS TOPCOUNT([DIM TUMOR].[Tumor Type].CHILDREN,5,( [Measures].[Patient Count]) 
); 
CREATE DYNAMIC SET CURRENTCUBE.[Cau13]
 AS TOPCOUNT([DIM TUMOR].[Tumor Type].CHILDREN,3,( [Measures].[Avr FollowMonth]) 
) ;                
CREATE MEMBER CURRENTCUBE.[Measures].[Dead Rate]
 AS IIF(
    [Measures].[Patient Count] = 0,
    NULL,
    (
        ( [Measures].[Patient Count], [DIM OUTCOME].[Survival Status].[Deceased] ) 
        / 
        [Measures].[Patient Count]
    )
), 
FORMAT_STRING = "#,##0.00%;-#,##0.00%", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'FACT CANCER';                  
CREATE MEMBER CURRENTCUBE.[Measures].[Avr tumorSize]
 AS [Measures].[Tumor Size] / [Measures].[Patient Count], 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'FACT CANCER';                 
CREATE MEMBER CURRENTCUBE.[Measures].[Avr Age]
 AS [Measures].[Age] /  [Measures].[Patient Count], 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'FACT CANCER';                 
CREATE MEMBER CURRENTCUBE.[Measures].[Avr FollowMonth]
 AS [Measures].[Follow Up Months] / [Measures].[Patient Count], 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'FACT CANCER'; </Text>
            </Command>
          </Commands>
        </MdxScript>
      </MdxScripts>
    </Cube>
  </Cubes>
